{
  "name": "ResolveApp",
  "description": "Facility Management System – FastAPI + React",
  "keywords": ["python", "fastapi", "react", "mongodb"],
  "buildpacks": [
    { "url": "heroku/nodejs" },
    { "url": "heroku/python" }
  ],
  "env": {
    "MONGODB_URL": {
      "description": "MongoDB Atlas connection string",
      "required": true
    },
    "DATABASE_NAME": {
      "description": "MongoDB database name",
      "value": "resolveapp"
    },
    "SECRET_KEY": {
      "description": "JWT signing secret – use a long random string",
      "generator": "secret",
      "required": true
    },
    "ALGORITHM": {
      "description": "JWT algorithm",
      "value": "HS256"
    },
    "ACCESS_TOKEN_EXPIRE_MINUTES": {
      "description": "JWT token expiry in minutes",
      "value": "1440"
    }
  },
  "formation": {
    "web": {
      "quantity": 1,
      "size": "basic"
    }
  }
}
